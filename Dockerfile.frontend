FROM node:20-alpine

WORKDIR /app

# Copy frontend files
COPY frontend/package.json frontend/package-lock.json* ./

# Install dependencies
RUN npm ci

# Copy source code
COPY frontend/ .

# Build
RUN npm run build

# Expose port for preview (optional)
EXPOSE 3000

# Serve (use http-server or similar for preview)
CMD ["npm", "run", "preview"]
